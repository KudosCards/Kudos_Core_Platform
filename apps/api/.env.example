NODE_ENV=development
PORT=3001

# Supabase Postgres — pooled connection for the app, direct connection for migrations.
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# Also used to derive the JWKS endpoint JwtAuthGuard verifies session tokens
# against (SUPABASE_URL + /auth/v1/.well-known/jwks.json) — no shared secret needed.
SUPABASE_URL="https://[PROJECT_REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="replace-me"

STRIPE_SECRET_KEY="sk_test_replace-me"
STRIPE_WEBHOOK_SECRET="whsec_replace-me"

# Recurring Stripe Price ids for the paid plans, read by the seed
# (prisma/seed.ts) to set plan_entitlements.stripe_price_id. Until set,
# subscription checkout returns a clean 409 "not yet configured". Optional.
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_CENTRE=

WEB_APP_URL="http://localhost:3000"

# Airtable-sourced card catalog (see docs/adr/0011-airtable-catalog-sync.md).
# A read-only Personal Access Token (data.records:read on the cards base) and
# the base id. Optional: without them the app boots and the catalog sync
# reports "not configured". AIRTABLE_CARDS_TABLE defaults to "Card List".
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_CARDS_TABLE="Card List"

# Optional
SENTRY_DSN=

# CRM API-key & OAuth-token encryption at rest (see integrations). Generate: openssl rand -hex 32
CREDENTIALS_ENCRYPTION_KEY=

# HubSpot OAuth (see docs/adr/0015). Optional: unset ⇒ connecting HubSpot returns "not enabled".
# Register a HubSpot app; set the redirect URI to this API's public host + the path below, and set
# the same value in the HubSpot app config. All three must be present for HubSpot to be enabled.
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=https://your-api-host/integrations/oauth/hubspot/callback

# Transactional email via Brevo (birthday reminders + guest receipts, ADR 0025).
# Optional: unset ⇒ the email client becomes a logged no-op (nothing sends).
# Brevo_API is a PLATFORM key (separate from the per-account CRM keys); the name
# matches the Railway variable exactly.
Brevo_API=
# The sender address — must be a VERIFIED sender in the Brevo account. Optional
# only if every email uses a Brevo template (which carries its own sender);
# required for the built-in HTML fallbacks.
EMAIL_FROM_ADDRESS=hello@kudoscards.co.uk
EMAIL_FROM_NAME=Kudos Cards
# Optional Brevo transactional template IDs — set one to design that email in
# the Brevo dashboard instead of using the built-in HTML. Unset ⇒ HTML fallback.
# Reminder template params:           {{ params.name }}, {{ params.calendarUrl }},
#                                     {{ params.birthdays }} ([{ name, date }] to loop)
# Guest-receipt template params:      {{ params.claimUrl }}
# Order-confirmation template params: {{ params.orderNumber }}, {{ params.cardCount }},
#                                     {{ params.total }}, {{ params.orderUrl }}
BREVO_REMINDER_TEMPLATE_ID=
BREVO_GUEST_RECEIPT_TEMPLATE_ID=
BREVO_ORDER_CONFIRMATION_TEMPLATE_ID=
