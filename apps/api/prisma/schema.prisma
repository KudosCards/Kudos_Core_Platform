// Kudos Cards platform — primary schema.
//
// Enum values here are the source of truth alongside packages/shared-types/src/enums.ts.
// Prisma can't import from TS, so any enum change must be made in both places in the
// same commit — see docs/adr/0001-stack-choice.md for why we accept that duplication.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Tenancy
// ---------------------------------------------------------------------------

enum AccountType {
  organisation
  individual
}

enum MembershipRole {
  owner
  admin
  staff
}

model Account {
  id               String   @id @default(uuid())
  type             AccountType
  name             String
  stripeCustomerId String?  @unique @map("stripe_customer_id")
  planId           String?  @map("plan_id")
  /// Guest one-off buyer's email — captured at Stripe checkout for the receipt
  /// and the account-claim link. Null for accounts created via normal signup
  /// (identity comes from the membership's user). See docs/adr/0025.
  contactEmail     String?  @map("contact_email")
  /// Single-use token that lets a guest claim (attach a login to) the account
  /// they just bought from. Set when a guest order is created, nulled on claim
  /// or expiry. A secret — never returned by the API (findById omits it).
  claimToken          String?   @unique @map("claim_token")
  claimTokenExpiresAt DateTime? @map("claim_token_expires_at")
  /// Whether we email this account upcoming-birthday reminders. Opt-out (default
  /// on); the reminder cron skips accounts with this false. See docs/adr/0025.
  reminderEmailsEnabled Boolean @default(true) @map("reminder_emails_enabled")
  /// Paid team seats beyond the plan's included allowance (Centre includes 3).
  /// The seat limit = PlanEntitlement.includedSeats + extraSeats; inviting past
  /// it is hard-blocked until a seat is added. Kept in sync with the Stripe
  /// subscription's per-seat item quantity. See docs/adr/0035-seat-based-billing.md.
  extraSeats       Int      @default(0) @map("extra_seats")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  memberships   Membership[]
  invites       Invite[]
  recipients    Recipient[]
  savedDesigns  SavedDesign[]
  batchOrders   BatchOrder[]
  walletEntries WalletLedgerEntry[]
  subscriptions Subscription[]
  auditLogs      AuditLogEntry[]
  apiKeys        AccountApiKey[]
  crmConnections CrmConnection[]
  recipientLists RecipientList[]
  notifications  Notification[]

  // Super-admin subscribers list is ordered newest-first.
  @@index([createdAt])
  @@map("accounts")
}

/// A persisted, per-user record of something that already happened in the
/// account and is worth telling a member about after the fact — an order paid,
/// an auto-send fired, a colleague joined. This is deliberately distinct from
/// the *computed* notification feed (notifications.service.ts, ADR 0030), which
/// derives live "action needed" items from current state and carries no
/// read/unread. An account-wide event fans out one row per active member, so
/// read state (readAt) is per-user. entityType/entityId let a producer stay
/// idempotent under retries (skip if a row for this kind+entity already exists).
/// userId is the Supabase Auth user id — not a Prisma FK, same as Membership.
/// See docs/adr/0034-notification-inbox.md.
model Notification {
  id         String    @id @default(uuid())
  accountId  String    @map("account_id")
  userId     String    @map("user_id")
  kind       String
  title      String
  body       String
  href       String?
  entityType String?   @map("entity_type")
  entityId   String?   @map("entity_id")
  readAt     DateTime? @map("read_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  // The unread badge + the member's inbox list, both newest-first per user.
  @@index([userId, createdAt])
  // Idempotency lookup: has this account already been notified about this event?
  @@index([accountId, kind, entityId])
  @@map("notifications")
}

/// A customer's connection to an external CRM (Brevo, …) that recipients are
/// synced *from*. The CRM API key is stored AES-256-GCM encrypted (see
/// common/crypto.service.ts) — never in plaintext. One connection per provider
/// per account. See docs/adr/0015-crm-integrations.md.
model CrmConnection {
  id       String @id @default(uuid())
  accountId String @map("account_id")
  /// The CRM: "brevo" (API key) or "hubspot" (OAuth) today; more later.
  provider String
  /// How this connection authenticates: "api_key" (Brevo) or "oauth" (HubSpot).
  authType String @default("api_key") @map("auth_type")

  /// AES-256-GCM-encrypted API key — set for api_key providers (Brevo), null for OAuth.
  encryptedApiKey String? @map("encrypted_api_key")

  /// OAuth credentials — set for oauth providers (HubSpot), null for api_key.
  /// Both tokens are AES-256-GCM-encrypted at rest, never stored in plaintext.
  encryptedAccessToken  String?   @map("encrypted_access_token")
  encryptedRefreshToken String?   @map("encrypted_refresh_token")
  /// When the access token expires — refreshed just-in-time before a sync.
  tokenExpiresAt        DateTime? @map("token_expires_at")
  /// The account's id in the provider (e.g. HubSpot hub/portal id) — display only.
  externalAccountId     String?   @map("external_account_id")

  /// Optional per-connection field mapping (CRM attribute name → our field).
  fieldMapping    Json?     @map("field_mapping")
  syncEnabled     Boolean   @default(true) @map("sync_enabled")
  lastSyncedAt    DateTime? @map("last_synced_at")
  lastSyncStatus  String?   @map("last_sync_status")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, provider])
  @@map("crm_connections")
}

/// A per-account API key for the inbound integrations endpoint (push contacts
/// into Recipients). Only the SHA-256 hash is stored — the plaintext key is
/// shown to the customer exactly once, at creation. See ADR 0015.
model AccountApiKey {
  id         String    @id @default(uuid())
  accountId  String    @map("account_id")
  label      String
  keyHash    String    @unique @map("key_hash")
  /// A short non-secret prefix (e.g. "kudos_ab12cd…") for display in the UI.
  prefix     String
  lastUsedAt DateTime? @map("last_used_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@map("account_api_keys")
}

/// userId references the Supabase Auth user (managed outside Prisma's schema),
/// so it is intentionally not a Prisma foreign key — just an indexed UUID.
model Membership {
  id        String         @id @default(uuid())
  accountId String         @map("account_id")
  userId    String         @map("user_id")
  role      MembershipRole
  /// The member's email, captured when the membership is created (from the
  /// signing-up user for the owner, from the invite for invited members) so the
  /// team-management UI can show who's who. Nullable for legacy rows. See ADR 0028.
  email     String?
  createdAt DateTime       @default(now()) @map("created_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, userId])
  @@index([userId])
  @@map("memberships")
}

enum InviteStatus {
  pending
  accepted
  revoked
}

/// A pending invitation for someone to join an account's team. Gated to plans
/// with teamSeatsEnabled (Centre). The `token` is a secret — whoever holds it
/// can join the account as the invited role — so it is never returned by the
/// API (only emailed to the invitee). See docs/adr/0028-multi-user-teams.md.
model Invite {
  id              String       @id @default(uuid())
  accountId       String       @map("account_id")
  /// Invitee email, lowercased. The accepting user's verified JWT email must
  /// match this, so a forwarded link can't be redeemed by someone else.
  email           String
  role            MembershipRole
  token           String       @unique
  status          InviteStatus @default(pending)
  invitedByUserId String?      @map("invited_by_user_id")
  expiresAt       DateTime     @map("expires_at")
  acceptedAt      DateTime?    @map("accepted_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  // One live invite per email per account — re-inviting replaces the old row.
  @@unique([accountId, email])
  @@index([accountId])
  @@map("invites")
}

// ---------------------------------------------------------------------------
// CRM
// ---------------------------------------------------------------------------

enum RecipientStatus {
  active
  lapsed
  archived
}

model Recipient {
  id            String          @id @default(uuid())
  accountId     String          @map("account_id")
  firstName     String          @map("first_name")
  lastName      String          @map("last_name")
  /// Nullable: not every occasion needs a DOB on file.
  dateOfBirth   DateTime?       @map("date_of_birth") @db.Date
  email         String?
  addressLine1  String?         @map("address_line1")
  addressLine2  String?         @map("address_line2")
  addressCity   String?         @map("address_city")
  addressPostcode String?       @map("address_postcode")
  addressCountry String?        @default("GB") @map("address_country")
  tags          String[]        @default([])
  /// Arbitrary per-recipient key→value fields, usable as {key} merge tokens on
  /// a card (e.g. {teacher}, {class}). See docs/adr/0033-richer-merge-tokens.md.
  customFields  Json?           @map("custom_fields")
  status        RecipientStatus @default(active)
  /// Where this recipient came from: "manual", "csv", "api", or a CRM id
  /// ("brevo", "hubspot", …). See docs/adr/0015-crm-integrations.md.
  source        String          @default("manual")
  /// The stable id of this contact in its source system (a CRM record id, or
  /// the caller's own id for the inbound API). Null for manual/CSV recipients.
  externalId    String?         @map("external_id")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  account   Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  occasions Occasion[]
  orderRecipients OrderRecipient[]
  listMemberships RecipientListMembership[]

  // Mirrors the legacy CSV-import dedupe rule: same name + postcode + DOB = same person.
  @@unique([accountId, firstName, lastName, addressPostcode, dateOfBirth], name: "recipient_dedupe_key")
  // Source-based identity for integrations: re-syncing a CRM contact updates
  // the same row instead of duplicating. externalId is null for manual/CSV
  // recipients, and Postgres treats NULLs as distinct, so they never collide.
  @@unique([accountId, source, externalId], name: "recipient_source_key")
  @@index([accountId, status])
  @@map("recipients")
}

/// A named grouping of recipients a subscriber curates by hand — e.g. a teacher's
/// "Year 4 class", "Year 5 class". Purely organisational: lists help filter and
/// personalise cards in bulk; they don't drive occasions or billing on their own.
/// See docs/adr/0016-recipient-events-and-lists.md.
model RecipientList {
  id        String   @id @default(uuid())
  accountId String   @map("account_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  account Account                   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  members RecipientListMembership[]

  // A list name is unique within an account so "Year 4 class" can't be created twice.
  @@unique([accountId, name], name: "recipient_list_name_key")
  @@index([accountId])
  @@map("recipient_lists")
}

/// Join row: a recipient's membership in a list (many-to-many). Cascade-deletes
/// with either side, so archiving a list or a recipient tidies the membership up.
model RecipientListMembership {
  listId      String   @map("list_id")
  recipientId String   @map("recipient_id")
  createdAt   DateTime @default(now()) @map("created_at")

  list      RecipientList @relation(fields: [listId], references: [id], onDelete: Cascade)
  recipient Recipient     @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@id([listId, recipientId])
  @@index([recipientId])
  @@map("recipient_list_memberships")
}

// ---------------------------------------------------------------------------
// Occasions & scheduling
// ---------------------------------------------------------------------------

enum OccasionType {
  birthday
  achievement
  leaver
  staff_recognition
  seasonal
  bespoke_campaign
}

enum OccasionSource {
  recurring_per_recipient
  one_off_campaign
}

enum OccasionStatus {
  scheduled
  pending_approval
  approved
  queued
  printed
  posted
  delivered
  skipped
}

model Occasion {
  id           String         @id @default(uuid())
  accountId    String         @map("account_id")
  /// Null for one_off_campaign occasions (e.g. an org-wide "Student of the Month" send).
  recipientId  String?        @map("recipient_id")
  type         OccasionType
  source       OccasionSource
  /// Optional human label for a hand-added recipient event ("Graduation", "End
  /// of exams") — lets the calendar show the real name rather than just the
  /// broad `type`. Null for auto-scheduled birthdays and campaign occasions.
  title        String?
  occasionDate DateTime       @map("occasion_date") @db.Date
  dispatchDate DateTime?      @map("dispatch_date") @db.Date
  status       OccasionStatus @default(scheduled)
  /// How this occasion is sent once approved. `asap` (default) means a human
  /// checks it out manually; `auto_send` means the auto-send cron creates the
  /// order, pays it from the wallet, and posts it timed to the dispatchDate —
  /// no manual checkout. See docs/adr/0013-auto-send.md.
  dispatchOption DispatchOption @default(asap) @map("dispatch_option")
  /// Postage class chosen at approval for auto_send occasions; drives both the
  /// stamp cost and the dispatchDate lead time. Ignored for `asap` occasions
  /// (postage is chosen per line at manual checkout).
  postageClass  PostageClass   @default(second_class) @map("postage_class")
  /// Set when an admin approves the occasion (see docs/adr/0006-phase-2-scope.md). Copied
  /// into OrderRecipient.savedDesignId by Phase 3's checkout flow — the design choice
  /// travels with the occasion instead of being re-selected at checkout.
  savedDesignId String?       @map("saved_design_id")
  /// When a birthday-reminder email covering this occasion was sent, so the
  /// daily reminder cron never emails the same upcoming occasion twice. Null
  /// until reminded. See docs/adr/0025.
  reminderSentAt DateTime?    @map("reminder_sent_at")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  recipient       Recipient?        @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  // Restrict, not the nullable-relation default of SetNull — an approved occasion
  // silently losing its design would be a worse state than blocking the delete.
  savedDesign     SavedDesign?      @relation(fields: [savedDesignId], references: [id], onDelete: Restrict)
  orderRecipients OrderRecipient[]

  // Prevents the scheduler from double-creating the same occasion instance on retry.
  @@unique([recipientId, type, occasionDate], name: "occasion_idempotency_key")
  @@index([accountId, status])
  @@index([dispatchDate])
  @@map("occasions")
}

// ---------------------------------------------------------------------------
// Card designer
// ---------------------------------------------------------------------------

model CardDesign {
  id           String   @id @default(uuid())
  category     String
  name         String
  thumbnailUrl String   @map("thumbnail_url")
  /// DesignDocument JSON — see packages/shared-types/src/card.ts for the shape.
  document     Json
  isActive     Boolean  @default(true) @map("is_active")
  /// The Airtable record id this design was synced from (null for seeded
  /// templates). Unique so the catalog sync can upsert in place — see
  /// docs/adr/0011-airtable-catalog-sync.md.
  externalId   String?  @unique @map("external_id")
  /// Human-facing product code from Airtable (e.g. "KC-BDAY-GEN-001"), shown
  /// to the ops team. Null for seeded templates.
  sku          String?  @map("sku")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  savedDesigns SavedDesign[]

  @@index([category, isActive])
  @@map("card_designs")
}

/// A personalised instance of a CardDesign, saved to an account's "My Designs".
model SavedDesign {
  id        String @id @default(uuid())
  accountId String @map("account_id")
  /// Null for a member's own uploaded artwork, which starts from a blank
  /// document rather than a catalog template. See docs/adr/0026.
  cardDesignId String?  @map("card_design_id")
  name         String
  document     Json
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  account         Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  cardDesign      CardDesign?      @relation(fields: [cardDesignId], references: [id])
  orderRecipients OrderRecipient[]
  occasions       Occasion[]

  @@index([accountId])
  @@map("saved_designs")
}

// ---------------------------------------------------------------------------
// Batch ordering
// ---------------------------------------------------------------------------

enum BatchOrderStatus {
  draft
  pending_payment
  paid
  fulfilling
  completed
  cancelled
}

enum PaymentMethod {
  card
  wallet
}

/// One order representing a whole batch (e.g. "10 birthday cards this week").
/// Deliberately one order with many recipient lines, not one cart line per
/// recipient — see docs/adr/0002-batch-order-model.md.
model BatchOrder {
  id                     String           @id @default(uuid())
  /// Human-friendly sequential order number (rendered as ORD-1035). Separate
  /// from the uuid id so ops/customers have a short reference. Sequence starts
  /// at 1000 (see the migration) so the first orders read ORD-1000+.
  orderNumber            Int              @unique @default(autoincrement()) @map("order_number")
  accountId              String           @map("account_id")
  /// The user who placed the order. Null for guest one-off purchases, which are
  /// created by an unauthenticated visitor against a fresh guest account with no
  /// membership. See docs/adr/0025.
  createdByUserId        String?          @map("created_by_user_id")
  status                 BatchOrderStatus @default(draft)
  currency               String           @default("GBP")
  subtotalMinor          Int              @default(0) @map("subtotal_minor")
  postageMinor           Int              @default(0) @map("postage_minor")
  totalMinor             Int              @default(0) @map("total_minor")
  paymentMethod          PaymentMethod?   @map("payment_method")
  stripePaymentIntentId  String?          @unique @map("stripe_payment_intent_id")
  createdAt              DateTime         @default(now()) @map("created_at")
  updatedAt              DateTime         @updatedAt @map("updated_at")

  account         Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  orderRecipients OrderRecipient[]

  @@index([accountId, status])
  // Super-admin dashboard: status-filtered lists + status aggregates (ordered by
  // date), and the default "all non-draft, newest first" list.
  @@index([status, createdAt])
  @@index([createdAt])
  @@map("batch_orders")
}

enum DispatchOption {
  asap
  auto_send
}

enum PostageClass {
  first_class
  second_class
}

enum OrderRecipientStatus {
  pending_approval
  approved
  queued
  printed
  posted
  delivered
  cancelled
}

/// One recipient's line within a BatchOrder. This is the fix for the legacy
/// system's N-identical-cart-lines checkout friction.
model OrderRecipient {
  id              String                @id @default(uuid())
  batchOrderId    String                @map("batch_order_id")
  recipientId     String                @map("recipient_id")
  occasionId      String?               @map("occasion_id")
  savedDesignId   String                @map("saved_design_id")
  shippingAddressLine1    String        @map("shipping_address_line1")
  shippingAddressLine2    String?       @map("shipping_address_line2")
  shippingAddressCity     String        @map("shipping_address_city")
  shippingAddressPostcode String        @map("shipping_address_postcode")
  shippingAddressCountry  String        @default("GB") @map("shipping_address_country")
  dispatchOption  DispatchOption
  postageClass    PostageClass
  /// Card price (VAT-inclusive, after the plan discount) for this one card.
  priceMinor      Int                   @map("price_minor")
  /// The stamp cost for this one card (per-card postage, VAT-exempt).
  postageMinor    Int                   @default(0) @map("postage_minor")
  status          OrderRecipientStatus  @default(pending_approval)
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")

  batchOrder  BatchOrder      @relation(fields: [batchOrderId], references: [id], onDelete: Cascade)
  recipient   Recipient       @relation(fields: [recipientId], references: [id])
  occasion    Occasion?       @relation(fields: [occasionId], references: [id])
  savedDesign SavedDesign     @relation(fields: [savedDesignId], references: [id])
  messagePage MessagePage?
  fulfillmentJob FulfillmentJob?

  @@index([batchOrderId])
  @@index([recipientId])
  @@map("order_recipients")
}

/// A card's QR-linked digital message page.
model MessagePage {
  id               String   @id @default(uuid())
  slug             String   @unique
  orderRecipientId String   @unique @map("order_recipient_id")
  message          String?
  emoji            String?
  videoUrl         String?  @map("video_url")
  viewCount        Int      @default(0) @map("view_count")
  createdAt        DateTime @default(now()) @map("created_at")

  orderRecipient OrderRecipient @relation(fields: [orderRecipientId], references: [id], onDelete: Cascade)

  @@map("message_pages")
}

// ---------------------------------------------------------------------------
// Billing — kept deliberately separate from BatchOrder/wallet billing so a
// plan is always a Stripe Subscription and a card batch is always a Stripe
// PaymentIntent or a wallet debit, never one conflated cart/subscription
// object (see docs/adr/0003-billing-separation.md).
// ---------------------------------------------------------------------------

enum SubscriptionStatus {
  trialing
  active
  past_due
  canceled
  incomplete
}

model Subscription {
  id                   String             @id @default(uuid())
  accountId            String             @map("account_id")
  planId               String             @map("plan_id")
  stripeSubscriptionId String             @unique @map("stripe_subscription_id")
  status               SubscriptionStatus
  currentPeriodEnd     DateTime           @map("current_period_end")
  createdAt            DateTime           @default(now()) @map("created_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  // Super-admin overview counts active subscriptions across all accounts.
  @@index([status])
  @@map("subscriptions")
}

enum WalletEntryType {
  topup
  charge
  refund
  adjustment
}

/// Append-only. Never UPDATE or DELETE a row — corrections are new entries
/// (type=adjustment), so the ledger is always a reliable audit trail.
model WalletLedgerEntry {
  id               String          @id @default(uuid())
  accountId        String          @map("account_id")
  type             WalletEntryType
  amountMinor      Int             @map("amount_minor")
  balanceAfterMinor Int            @map("balance_after_minor")
  reference        String?
  createdAt        DateTime        @default(now()) @map("created_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, createdAt])
  @@map("wallet_ledger_entries")
}

/// Per-plan limits and feature gates, enforced centrally in the API rather
/// than scattered ad-hoc checks (e.g. the legacy "you can add 12 more
/// contacts" banner and the Pro-only auto-send gate).
model PlanEntitlement {
  planId              String  @id @map("plan_id")
  recipientCap        Int?    @map("recipient_cap") // null = unlimited
  batchOrderMaxSize    Int     @default(20) @map("batch_order_max_size")
  cardDiscountPercent  Decimal @default(0) @db.Decimal(5, 2) @map("card_discount_percent")
  autoSendEnabled      Boolean @default(false) @map("auto_send_enabled")
  /// Whether the plan may upload its own artwork as a custom card design
  /// (rather than only personalising catalog templates). See docs/adr/0026.
  customArtworkEnabled Boolean @default(false) @map("custom_artwork_enabled")
  /// Whether the plan may invite additional team members (multi-user org).
  /// Centre-tier only today. See docs/adr/0028-multi-user-teams.md.
  teamSeatsEnabled     Boolean @default(false) @map("team_seats_enabled")
  /// Team seats included in the plan's base price before per-seat charges kick
  /// in (Centre includes 3; single-user plans 1). See docs/adr/0035-seat-based-billing.md.
  includedSeats        Int     @default(1) @map("included_seats")
  /// Null for the free plan, which has no Stripe subscription object at all.
  stripePriceId       String? @map("stripe_price_id")

  @@map("plan_entitlements")
}

// ---------------------------------------------------------------------------
// Fulfillment — v1 is an internal ops queue (manual print/post); this shape
// is provider-agnostic so a real print-API vendor can be plugged in later.
// ---------------------------------------------------------------------------

enum FulfillmentJobStatus {
  pending
  in_progress
  printed
  posted
  delivered
  failed
}

model FulfillmentJob {
  id                String               @id @default(uuid())
  orderRecipientId  String               @unique @map("order_recipient_id")
  status            FulfillmentJobStatus @default(pending)
  assignedToUserId  String?              @map("assigned_to_user_id")
  printedAt         DateTime?            @map("printed_at")
  postedAt          DateTime?            @map("posted_at")
  deliveredAt       DateTime?            @map("delivered_at")
  trackingReference String?              @map("tracking_reference")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")

  orderRecipient OrderRecipient @relation(fields: [orderRecipientId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("fulfillment_jobs")
}

/// A Kudos Cards internal operator (print/post staff), distinct from a tuition
/// centre's Membership. Presence here grants cross-account access to the
/// fulfillment queue via PlatformAdminGuard — see docs/adr/0010. userId is the
/// Supabase auth user id, same source as Membership.userId.
model PlatformAdmin {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("platform_admins")
}

// ---------------------------------------------------------------------------
// Compliance
// ---------------------------------------------------------------------------

/// Records who accessed/exported recipient (children's) personal data — a
/// UK GDPR non-negotiable, not optional polish. Written by the API layer,
/// never the client.
model AuditLogEntry {
  id          String   @id @default(uuid())
  accountId   String   @map("account_id")
  actorUserId String   @map("actor_user_id")
  action      String
  targetType  String   @map("target_type")
  targetId    String   @map("target_id")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, createdAt])
  @@index([targetType, targetId])
  @@map("audit_log_entries")
}
